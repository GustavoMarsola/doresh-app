# App
APP_NAME=doresh_backend
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=development
DEBUG=True
X_API_KEY=change-me-in-production
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# FastAPI performance
FASTAPI_WORKERS=1
FASTAPI_HTTP_MAX_CONNECTIONS=2000
FASTAPI_TIMEOUT_GRACEFUL_SHUTDOWN=100

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
EMAIL_TOKEN_EXPIRE_MINUTES=240

# Database — docker-compose overrides HOST and PORT via environment block
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=doresh
DATABASE_USER=doresh
DATABASE_PWD=doresh
DATABASE_DRIVER=psycopg2
DATABASE_ASYNC_DRIVER=asyncpg
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT_SECONDS=2
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=3600
DATABASE_ECHO_SQL=False

# Also set for docker-compose healthcheck / volume vars
DB_NAME=doresh
DB_USER=doresh
DB_PASSWORD=doresh

# Redis — docker-compose overrides HOST and PORT via environment block
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=0.1
REDIS_HEALTH_CHECK_INTERVAL=3
REDIS_CACHE_EXPIRATION=600

# Logging
LOG_LEVEL=INFO

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASSWORD=your-app-password

# Asaas (payment gateway)
ASAAS_HOST=https://api-sandbox.asaas.com/v3
ASAAS_ACCESS_TOKEN=your-asaas-token

# OpenAI
OPENAI_API_KEY=your-openai-key
OPENAI_API_GPT_MODEL=gpt-4.1-mini
OPENAI_ASSISTANT_ID=your-assistant-id
IS_TEST_MODE=True

# n8n
N8N_USER=doresh_n8n
N8N_PASSWORD=changeme
